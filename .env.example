# Environment Variables for RYTM Wellness Tracking Platform
# Copy this file to .env.local for local development
# For production, set these in your deployment environment

# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# AI Services
# OpenAI API key for meal photo analysis
OPENAI_API_KEY=your-openai-api-key-here
# OpenRouter API key for LLM services (journaling, coaching)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Authentication
# NextAuth URL (usually your app's URL)
NEXTAUTH_URL=http://localhost:3000

# Fitbit Integration
FITBIT_CLIENT_ID=your-fitbit-client-id-here
FITBIT_CLIENT_SECRET=your-fitbit-client-secret-here
FITBIT_REDIRECT_URI=http://localhost:3000/api/fitbit/callback

# WHOOP Integration
WHOOP_CLIENT_ID=your-whoop-client-id-here
WHOOP_CLIENT_SECRET=your-whoop-client-secret-here

# Email Configuration (for daily streak reports)
REPORT_TO_EMAIL=your-email@example.com
REPORT_TIMEZONE=America/New_York
REPORT_CUTOFF_HOUR=14
REPORT_CUTOFF_MIN=30
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
REPORT_FROM_EMAIL=reports@yourapp.com

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RAMADAN_DECOR=0