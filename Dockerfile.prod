# Build stage
FROM node:20-alpine AS builder
WORKDIR /app

# ✅ Accept build-time args
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG SUPABASE_SERVICE_ROLE_KEY
ARG NEXTAUTH_SECRET
ARG NEXTAUTH_URL
ARG OPENAI_API_KEY
ARG FITBIT_CLIENT_ID
ARG FITBIT_CLIENT_SECRET
ARG FITBIT_REDIRECT_URI
ARG BUILD_TIME

# ✅ Make them available during `npm run build`
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
ENV NEXTAUTH_SECRET=$NEXTAUTH_SECRET
ENV NEXTAUTH_URL=$NEXTAUTH_URL
ENV OPENAI_API_KEY=$OPENAI_API_KEY
ENV FITBIT_CLIENT_ID=$FITBIT_CLIENT_ID
ENV FITBIT_CLIENT_SECRET=$FITBIT_CLIENT_SECRET
ENV FITBIT_REDIRECT_URI=$FITBIT_REDIRECT_URI
ENV BUILD_TIME=$BUILD_TIME

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build